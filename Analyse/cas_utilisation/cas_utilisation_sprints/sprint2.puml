@startuml sprint2
title Sprint 2 — Justificatifs & Consultation\nAttendanceFlow-AMS

left to right direction

skinparam usecase {
  BackgroundColor #EAFAF1
  BorderColor #1E8449
  ArrowColor #1E8449
}
skinparam actor {
  BorderColor #1E8449
  BackgroundColor #D5F5E3
}

actor "Étudiant" as Student
actor "Administrateur" as Admin

rectangle "Sprint 2 — Justificatifs (Application Mobile & Web)" {
  usecase "S'authentifier" as UC01
  usecase "Soumettre un justificatif\n(Upload PDF/Image)" as UC04
  usecase "Consulter les absences\net statistiques" as UC05
  usecase "Valider / Réfuter un\njustificatif" as UC06
  usecase "Suivi par code couleur\n(Dashboard Admin)" as UC07

  UC04 ..> UC01 : <<include>>
  UC05 ..> UC01 : <<include>>
  UC06 ..> UC01 : <<include>>
  UC07 ..> UC01 : <<include>>
  
  UC06 <.. UC07 : <<extend>>
}

Student -- UC04
Student -- UC05

Admin -- UC06
Admin -- UC07

@enduml
